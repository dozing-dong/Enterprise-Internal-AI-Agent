# ─── AWS / Bedrock ───────────────────────────────────────────────────────────
AWS_PROFILE=default
AWS_REGION=us-east-1

# Chat / completion model (Claude via Bedrock)
BEDROCK_CHAT_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0

# Embedding model (Amazon Titan)
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0

# Rerank model — note: bedrock-agent-runtime, may need a different region
BEDROCK_RERANK_MODEL_ID=amazon.rerank-v1:0
BEDROCK_RERANK_REGION=us-west-2

# ─── PostgreSQL / pgvector ────────────────────────────────────────────────────
PGVECTOR_CONNECTION=postgresql+psycopg://postgres:your_password@127.0.0.1:5432/rag_demo

# ─── Retrieval tuning (optional overrides) ───────────────────────────────────
# RETRIEVER_CANDIDATE_K=20
# RERANK_ENABLED=true
# RERANK_TOP_K=5
# RRF_K=60
# BM25_TOKENIZER_NGRAM=2
# LANGGRAPH_MAX_ITERATIONS=2
# LANGGRAPH_MIN_SOURCES=1

# ─── History backend ─────────────────────────────────────────────────────────
# postgres (default) or memory (tests / no-DB mode)
# HISTORY_BACKEND=postgres

# ─── Employee directory (optional) ───────────────────────────────────────────
# EMPLOYEE_SEED_ON_STARTUP=true

# ─── Multi-Agent / MCP ───────────────────────────────────────────────────────
# MULTI_AGENT_ENABLED=true

# Brave Search — requires a valid API key from https://brave.com/search/api/
BRAVE_API_KEY=your_brave_api_key_here

# Weather MCP server is project-local (Open-Meteo, no key required)
# MCP_WEATHER_ENABLED=true

# Business Calendar MCP server is project-local (holidays library)
# MCP_BUSINESS_CALENDAR_ENABLED=true
